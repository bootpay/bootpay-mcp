{
  "name": "@bootpay/mcp",
  "version": "2.0.2",
  "description": "Bootpay MCP Server — 결제·커머스 개발자 문서 검색, 관리자 도구, AI 에이전트 연동",
  "type": "module",
  "main": "dist/entry-stdio.js",
  "bin": {
    "bootpay-mcp": "dist/entry-stdio.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bootpay/bootpay-mcp"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "bootpay",
    "payment",
    "korea",
    "pg",
    "model-context-protocol",
    "ai",
    "llm"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/entry-stdio.ts",
    "start": "node dist/entry-stdio.js",
    "dev:workers": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sync": "tsx scripts/sync-to-kv.ts",
    "sync:deploy": "tsx scripts/sync-to-kv.ts && wrangler deploy",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/node": "^22.15.0",
    "gray-matter": "^4.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.14.1"
  },
  "files": [
    "dist"
  ]
}
